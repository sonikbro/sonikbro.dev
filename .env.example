# Fine-grained GitHub PAT used by /api/post-stats to read discussion counts.
# Required permissions: Repository → Discussions: Read-only
# Repository: sonikbro/sonikbro.dev
GITHUB_TOKEN=

# Spotify credentials used by /api/now-playing to show the currently playing track.
# 1. Create an app at https://developer.spotify.com/dashboard
# 2. Set a Redirect URI (e.g. http://localhost:3000/callback) and copy Client ID + Secret below
# 3. Run a one-time OAuth flow with scope `user-read-currently-playing` to get a refresh token
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
